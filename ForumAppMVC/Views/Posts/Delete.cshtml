@model MVCForumApp.Models.Post
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Delete";
    var currentUserId = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId");

}
<h1>Delete the post</h1>

@if (currentUserId != null && Model != null && currentUserId == Model.UserId)
{
    <div class="alert alert-danger">
        <h3>Are you sure you want to delete this post?</h3>
        <p>This action cannot be undone.</p>
    </div>

    <div>

        <dl class="row">
            <dt class="col-sm-2">Topic</dt>
            <dd class="col-sm-10 text-primary"><strong>@Model.Topic.Title</strong></dd>

            <dt class="col-sm-2">Content</dt>
            <dd class="col-sm-10">@Model.Content</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" /> |
            <a asp-controller="Topics" asp-action="Details" asp-route-id="@Model.TopicId" class="btn btn-secondary">Cancel</a>

        </form>
    </div>
}
else
{
    <div class="alert alert-warning">
        <h1>Access Denied</h1>
        <p>ou can't delete a post unless you are logged in as it's creator</p>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Log in</a>
    </div>

}


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
