@model MVCForumApp.Models.Post
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Add post";
    var currentUserId = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId");
}

<h1>Add post</h1>
<hr />

@if (currentUserId != null)
{

    <div class="row">
        <div class="col-md-4">


            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="Content" class="control-label"></label>
                    <input asp-for="Content" class="form-control" />
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <input type="hidden" asp-for="TopicId" />

           
                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Add post</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    <a asp-controller="Topics" asp-action="Details" asp-route-id="@Model.TopicId" class="btn btn-secondary">Cancel</a>
                </div>

            </form>


        </div>
    </div>
}
else
{
    <div class="alert alert-warning">
        <h1>You can't make posts without logging in</h1>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Log in</a>
    </div>
}
}
<div>
    <a asp-controller="Topics" asp-action="Index">Back to topics</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
