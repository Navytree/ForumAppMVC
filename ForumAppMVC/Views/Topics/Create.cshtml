@model MVCForumApp.Models.Topic
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Make topic";
    var currentUserId = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId");
}

<h1>Make topic</h1>
<hr />

@if (currentUserId != null)
{

    <div class="row">
        <div class="col-md-4">


            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="Title" class="control-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="control-label"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Add topic</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>


        </div>
    </div>
}
else
{
    <div class="alert alert-warning">
        <h1>You can't make topics without logging in</h1>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Log in</a>
    </div>
}

<div>
    <a asp-action="Index">Back to topics</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
